# Flask Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Groq API Key for accident image analysis
GROQ_API_KEY=your_groq_api_key_here

# Gemini API Key for first-aid chatbot
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model (default: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# Gemini vision model for accident image analysis (default: gemini-1.5-flash)
GEMINI_VISION_MODEL=gemini-1.5-flash

# JWT Secret Key - CHANGE THIS IN PRODUCTION!
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# JWT Token Expiration in seconds (default: 86400 = 1 day)
JWT_EXP_SECONDS=86400

# MongoDB Connection URI
MONGO_URI=mongodb+srv://Dharun:Dharun2712@cluster0.yr5quzl.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1
